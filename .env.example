# Rollcall service configuration. Copy to .env and fill in.

# --- Server ---
PORT=8080

# Path to the SQLite database file (created on first run).
DATABASE_PATH=./data/rollcall.db

# --- Twilio ---
# From the Twilio console. The auth token is used to validate the
# X-Twilio-Signature on every inbound webhook, so it must be correct.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number (E.164) that riders text. Used as the "From"
# for all outbound fan-out messages.
TWILIO_FROM_NUMBER=+15555555555

# The public HTTPS URL Twilio calls for inbound SMS, exactly as configured
# in the Twilio console (scheme + host + path). Signature validation hashes
# this URL, so it must match byte-for-byte, e.g.
#   https://rollcall.example.com/webhooks/twilio
PUBLIC_WEBHOOK_URL=https://rollcall.example.com/webhooks/twilio

# Set to "true" to skip Twilio signature validation and skip real SMS sends
# (outbound messages are logged to the console instead). For local dev only.
DRY_RUN=false

# --- Behavior ---
# Default ride-session lifetime, in hours.
DEFAULT_EXPIRY_HOURS=3

# How often the expiry sweep runs, in seconds.
SWEEP_INTERVAL_SECONDS=60

# How many days of message_log to retain before pruning.
LOG_RETENTION_DAYS=30
